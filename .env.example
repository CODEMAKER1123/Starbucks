# ─── OPTIONAL MOCK/LOCAL MODES ────────────────────────────────────────────────
# Leave unset to auto-detect: if the real API key exists, live mode is used;
# otherwise the app falls back to mock/local behavior.
EMAIL_DELIVERY_MODE=mock
COMPANYCAM_MODE=mock
WORKIZ_MODE=mock

# ─── LIVE SERVICE CREDENTIALS ─────────────────────────────────────────────────

# Resend (email sending) — sign up at resend.com
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=yourname@yourdomain.com
EMAIL_SENDER_NAME=Your Name
EMAIL_REPLY_TO=your.email@rollingsuds.com
EMAIL_CC=your.email@rollingsuds.com

# CompanyCam — get token from Your Company → Account → Access Tokens
COMPANYCAM_API_TOKEN=your_companycam_token

# Company info (shown on invoices and in the app)
NEXT_PUBLIC_COMPANY_NAME=Rolling Suds of [Your Territory]
NEXT_PUBLIC_COMPANY_PHONE=(555) 000-0000
NEXT_PUBLIC_COMPANY_EMAIL=your.email@rollingsuds.com

# Workiz API — optional
WORKIZ_API_TOKEN=your_workiz_api_token
WORKIZ_BASE_URL=https://api.workiz.com/api/v1
